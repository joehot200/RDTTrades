{
  "destinations": {
    "private_discord": {
      "enabled": true,
      "secret_env": "DISCORD_WEBHOOK_URL",
      "filters": {
        "post_all_entries": true,
        "post_all_exits": true
      }
    },
    "rdt_filter": {
      "enabled": true,
      "secret_env": "RDT_FILTER_DISCORD_WEBHOOK_URL",
      "filters": {
        "min_stock_price": 10,
        "min_option_dte": 7,
        "min_option_contract_cost": 100,
        "require_posted_entry_for_exit": true,
        "max_new_entries_per_day": 3
      }
    }
  }
}
