{
  "destinations": {
    "private_discord": {
      "enabled": true,
      "secret_env": "DISCORD_WEBHOOK_URL",
      "include_local_timestamp": true,
      "timestamp_time_zone": "Europe/London",
      "filters": {
        "post_all_entries": true,
        "post_all_exits": true,
        "max_posts_per_run": 20,
        "block_if_state_missing_over_count": 50
      }
    },
    "rdt_filter": {
      "enabled": true,
      "secret_env": "RDT_FILTER_DISCORD_WEBHOOK_URL",
      "include_local_timestamp": false,
      "filters": {
        "min_stock_price": 10,
        "min_option_dte": 7,
        "min_option_contract_cost": 100,
        "require_posted_entry_for_exit": true,
        "max_new_entries_per_day": 3,
        "suppress_round_trips_under_minutes": 15,
        "max_posts_per_run": 4,
        "block_if_state_missing_over_count": 3
      }
    }
  }
}
